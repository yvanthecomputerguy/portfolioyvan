---
interface SkillItem {
  name: string;
  detail: string;
}

interface Props {
  category: string;
  items: SkillItem[];
}

const { category, items } = Astro.props as Props;
---

<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:border-slate-300 hover:shadow-md">
  <h2 class="text-2xl font-semibold tracking-tight">{category}</h2>

  <ul class="mt-5 space-y-4">
    {items.map((item) => (
      <li class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-sm font-semibold text-slate-900">{item.name}</p>
        <p class="mt-1 text-sm leading-6 text-slate-600">{item.detail}</p>
      </li>
    ))}
  </ul>
</section>