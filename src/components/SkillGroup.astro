---
interface Props {
  category: string;
  items: string[];
}

const { category, items } = Astro.props as Props;
---

<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="text-2xl font-semibold tracking-tight">{category}</h2>

  <ul class="mt-5 flex flex-wrap gap-3">
    {items.map((item) => (
      <li class="rounded-full bg-slate-100 px-4 py-2 text-sm font-medium text-slate-700">
        {item}
      </li>
    ))}
  </ul>
</section>