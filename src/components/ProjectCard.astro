---
const { title, description, link = "#" } = Astro.props;
---

<article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-md">
  <h2 class="text-2xl font-semibold tracking-tight">{title}</h2>

  <p class="mt-3 leading-7 text-slate-600">
    {description}
  </p>
 <div class="mt-5 flex items-center justify-between"></div>
  <a
    href={link}
    class="mt-5 inline-flex items-center font-medium text-slate-900 hover:underline"
  >
    View project →
  </a>
  link && link !== "#" ? (
      <a
        href={link}
        target="_blank"
        class="text-sm text-slate-500 hover:text-slate-900"
      >
        GitHub ↗
      </a>
    ) : null}
  </div>
</article>