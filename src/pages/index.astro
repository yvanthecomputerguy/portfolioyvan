---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const featuredProjects = projects.slice(0, 2);
---

<MainLayout title="Home">
  <section class="grid items-center gap-12 py-16 md:grid-cols-2 md:gap-16 md:py-24">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">
        Portfolio
      </p>

      <h1 class="max-w-2xl text-5xl font-bold leading-tight tracking-tight md:text-6xl">
        YVAN — IT professional with 10+ years of experience, building and understanding real systems.
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-8 text-slate-600">
        I work across development, networking, and systems — building practical applications while understanding the infrastructure behind them.
        This portfolio reflects real projects, not just concepts.
      </p>

      <p class="mt-4 max-w-xl text-lg leading-8 text-slate-600">
        I focus on how things actually work — from code to systems to deployment.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/projects"
          class="rounded-xl bg-slate-900 px-6 py-3 font-medium text-white transition duration-200 hover:-translate-y-0.5 hover:bg-slate-800"
        >
          View Projects
        </a>

        <a
          href="/about"
          class="rounded-xl border border-slate-300 px-6 py-3 font-medium transition duration-200 hover:bg-slate-100"
        >
          About Me
        </a>
      </div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-widest text-slate-500">
        Technical Profile
      </p>

      <div class="mt-6 space-y-4">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">
            Experience
          </p>
          <p class="mt-2 text-2xl font-bold tracking-tight text-slate-900">
            10+ Years in IT
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-3 md:grid-cols-1 lg:grid-cols-3">
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm font-semibold text-slate-900">Development</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              Practical web projects, structured frontend work, and backend logic.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm font-semibold text-slate-900">Networking</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              Network setup, cabling, connectivity, and infrastructure support.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm font-semibold text-slate-900">Systems</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              Windows Server, Linux, virtualization, and system administration.
            </p>
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-900 p-5 text-white">
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-300">
            Working Style
          </p>
          <p class="mt-2 text-sm leading-6 text-slate-100">
            I focus on how things work in practice — from code and deployment to infrastructure and maintenance.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-8">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">
          Featured Work
        </p>
        <h2 class="text-3xl font-bold tracking-tight">Selected Projects</h2>
      </div>

      <a href="/projects" class="text-sm font-medium text-slate-500 hover:text-slate-900">
        View all projects
      </a>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.title}
          description={project.description}
          link={`/projects/${project.slug}`}
        />
      ))}
    </div>
  </section>
</MainLayout>