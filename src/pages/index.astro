---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const featuredProjects = projects.slice(0, 2);
---

<MainLayout title="Home">
  <section class="grid items-center gap-12 py-16 md:grid-cols-2 md:py-24">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">
        Portfolio
      </p>

      <h1 class="max-w-2xl text-5xl font-bold leading-tight tracking-tight md:text-6xl">
        Hi, I'm YVAN. I build practical web projects and keep learning by doing.
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-8 text-slate-600">
        This site is where I showcase my work, skills, and progress as a developer.
        I’m building it myself as part of my learning journey.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/projects"
          class="rounded-xl bg-slate-900 px-6 py-3 font-medium text-white transition hover:-translate-y-0.5 hover:bg-slate-800"
        >
          View Projects
        </a>

        <a
          href="/about"
          class="rounded-xl border border-slate-300 px-6 py-3 font-medium transition hover:bg-slate-100"
        >
          About Me
        </a>
      </div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-widest text-slate-500">
        Current Focus
      </p>

      <ul class="mt-6 space-y-4 text-slate-700">
        <li>Building real projects to strengthen frontend and backend skills</li>
        <li>Learning modern component-based development with Astro</li>
        <li>Turning practical work into a public portfolio</li>
      </ul>
    </div>
  </section>

  <section class="py-8">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">
          Featured Work
        </p>
        <h2 class="text-3xl font-bold tracking-tight">Selected Projects</h2>
      </div>

      <a href="/projects" class="text-sm font-medium text-slate-500 hover:text-slate-900">
        View all projects
      </a>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.title}
          description={project.description}
          link={`/projects/${project.slug}`}
        />
      ))}
    </div>
  </section>
</MainLayout>