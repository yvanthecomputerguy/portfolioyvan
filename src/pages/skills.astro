---
import MainLayout from '../layouts/MainLayout.astro';
import SkillGroup from '../components/SkillGroup.astro';
import { skillGroups } from '../data/skills';
---

<MainLayout title="Skills">
  <section>
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">
  Skills
  </p>

  <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
  Technical skills applied through real work
  </h1>

  <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
   My skills are developed through hands-on projects, with a focus on understanding how applications, infrastructure, and systems work together in practice.
  </p>

  <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <p class="leading-7 text-slate-700">
    I focus on building practical capability across development, infrastructure, and systems administration — not just using tools, but understanding how they fit together in real environments.
  </p>
  </div>

    <div class="mt-12 grid gap-6">
      {skillGroups.map((group) => (
        <SkillGroup category={group.category} items={group.items} />
      ))}
    </div>
  </section>
</MainLayout>