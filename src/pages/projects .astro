---
import MainLayout from '../layouts/MainLayout.astro';
import { projects } from '../data/projects';
---

<MainLayout title="Projects">
  <section class="space-y-10">
    <div>
      <p class="text-sm font-semibold uppercase tracking-widest text-slate-500">
        Projects
      </p>

      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
        Selected Work
      </h1>

      <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
        A selection of projects I have built while developing my technical skills through practical work.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="group block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-slate-300 hover:shadow-md"
        >
          <h2 class="text-2xl font-semibold tracking-tight">
            {project.title}
          </h2>

          <p class="mt-3 text-slate-600">
            {project.description}
          </p>

          <p class="mt-6 text-sm font-medium text-slate-700 transition group-hover:translate-x-1">
            View project →
          </p>
        </a>
      ))}
    </div>
  </section>
</MainLayout>