---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact">
  <section class="max-w-3xl">
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">
      Contact
    </p>

    <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
      Get in touch
    </h1>

    <p class="mt-6 text-lg leading-8 text-slate-600">
      This page will eventually include my professional contact details and links.
      For now, it acts as a structured placeholder while the portfolio is being built out.
    </p>

    <div class="mt-10 grid gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-widest text-slate-500">Email</p>
        <p class="mt-2 text-slate-700">yvanthecomputerguy@gmail.com</p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-widest text-slate-500">GitHub</p>
        <p class="mt-2 text-slate-700">github.com/yvanthecomputerguy</p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-widest text-slate-500">LinkedIn</p>
        <p class="mt-2 text-slate-700">linkedin.com/in/yvanegbertwillems</p>
      </div>
    </div>
  </section>
</MainLayout>