---
import MainLayout from '../../layouts/MainLayout.astro';
import { projects } from '../../data/projects';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const project = Astro.props.project;
---

<MainLayout title={project.title}>
  <article class="max-w-3xl">
    <a
      href="/projects"
      class="text-sm font-medium text-slate-500 transition hover:text-slate-900 hover:underline"
    >
      ← Back to Projects
    </a>

    <p class="mt-6 text-sm font-semibold uppercase tracking-widest text-slate-500">
      Project Detail
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight md:text-5xl">
      {project.title}
    </h1>

    <p class="mt-6 text-lg leading-8 text-slate-600">
      {project.longDescription}
    </p>

    <div class="mt-10">
      <h2 class="text-xl font-semibold">Technologies Used</h2>

      <ul class="mt-4 flex flex-wrap gap-3">
        {project.tech.map((item) => (
          <li class="rounded-full bg-slate-200 px-4 py-2 text-sm font-medium text-slate-700">
            {item}
          </li>
        ))}
      </ul>
    </div>
  </article>
</MainLayout>