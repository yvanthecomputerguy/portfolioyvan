---
import MainLayout from '../../layouts/MainLayout.astro';
import { projects } from '../../data/projects';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<MainLayout title={project.title}>
  <section class="mx-auto max-w-3xl space-y-12">
    <div>
      <p class="text-sm font-semibold uppercase tracking-widest text-slate-500">
        Project
      </p>

      <h1 class="mt-2 text-4xl font-bold tracking-tight md:text-5xl">
        {project.title}
      </h1>

      <p class="mt-4 text-lg leading-8 text-slate-600">
        {project.description}
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      {project.tech.map((tech) => (
        <span class="rounded-md border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700">
          {tech}
        </span>
      ))}
    </div>

    <div class="mt-6 flex flex-wrap gap-4">
      {project.github && project.github !== '#' && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 transition duration-200 hover:border-slate-300 hover:bg-slate-50"
        >
          View Code
        </a>
      )}

      {project.live && project.live !== '#' && (
        <a
          href={project.live}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white transition duration-200 hover:bg-slate-700"
        >
          Live Demo
        </a>
      )}
    </div>

    <div class="grid gap-8">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:border-slate-300 hover:shadow-md">
        <h2 class="text-2xl font-semibold tracking-tight">Overview</h2>
        <p class="mt-4 leading-8 text-slate-600">{project.overview}</p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:border-slate-300 hover:shadow-md">
        <h2 class="text-2xl font-semibold tracking-tight">Problem</h2>
        <p class="mt-4 leading-8 text-slate-600">{project.problem}</p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:border-slate-300 hover:shadow-md">
        <h2 class="text-2xl font-semibold tracking-tight">Solution</h2>
        <p class="mt-4 leading-8 text-slate-600">{project.solution}</p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:border-slate-300 hover:shadow-md">
        <h2 class="text-2xl font-semibold tracking-tight">Result</h2>
        <p class="mt-4 leading-8 text-slate-600">{project.result}</p>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:border-slate-300 hover:shadow-md">
      <h2 class="text-2xl font-semibold tracking-tight">How It Works</h2>

      <ul class="mt-4 list-disc space-y-2 pl-5 text-slate-600 marker:text-slate-400">
        {project.howItWorks.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    <div>
      <a
        href="/projects"
        class="inline-flex rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 transition duration-200 hover:border-slate-300 hover:bg-slate-50"
      >
        Back to Projects
      </a>
    </div>
  </section>
</MainLayout>